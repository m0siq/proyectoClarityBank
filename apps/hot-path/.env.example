# Variables de entorno para desarrollo local del hot-path
# Copia este archivo como .env y rellena con tus recursos Azure
# NUNCA commitas el .env (está en .gitignore)

# ── Azure Identity ────────────────────────────────────────────────────────────
# Solo necesario si usas una user-assigned Managed Identity.
# Deja vacío para usar system-assigned MI o az login en local.
HOTPATH_AZURE_CLIENT_ID=

# ── Event Hubs ────────────────────────────────────────────────────────────────
HOTPATH_EVENT_HUB_NAMESPACE=ehns-banking-dev
HOTPATH_EVENT_HUB_NAME=transactions
HOTPATH_EVENT_HUB_CONSUMER_GROUP=$Default
HOTPATH_CHECKPOINT_STORAGE_ACCOUNT=stbankingdev
HOTPATH_CHECKPOINT_CONTAINER=checkpoints

# ── Cosmos DB ─────────────────────────────────────────────────────────────────
HOTPATH_COSMOS_ACCOUNT=cosmos-banking-dev
HOTPATH_COSMOS_DATABASE=banking
HOTPATH_COSMOS_CONTAINER_TRANSACTIONS=transactions
HOTPATH_COSMOS_CONTAINER_PROFILES=user_profiles
HOTPATH_COSMOS_CONTAINER_FEEDBACK=feedback_loop

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
HOTPATH_OPENAI_ENDPOINT=https://openai-banking-dev.openai.azure.com/
HOTPATH_OPENAI_DEPLOYMENT_L2=gpt-4o-mini
HOTPATH_OPENAI_API_VERSION=2024-10-01-preview
HOTPATH_OPENAI_TIMEOUT_SECONDS=2.0

# ── fastText model ────────────────────────────────────────────────────────────
# Si el archivo existe localmente, se usa directamente.
# Si no existe y fasttext_model_uri está configurado, se descarga del Blob.
HOTPATH_FASTTEXT_MODEL_PATH=./src/hot_path/ml_assets/model.bin
HOTPATH_FASTTEXT_MODEL_URI=
HOTPATH_FASTTEXT_MODEL_VERSION=fasttext-dev

# ── Clasificación y anomalías ─────────────────────────────────────────────────
HOTPATH_CONFIDENCE_THRESHOLD=0.85
HOTPATH_ZSCORE_THRESHOLD=3.0
HOTPATH_PROFILE_CACHE_TTL_SECONDS=300

# ── Telemetría ────────────────────────────────────────────────────────────────
# Deja vacío en local para usar un proveedor nulo (no envía a Azure).
HOTPATH_APPLICATIONINSIGHTS_CONNECTION_STRING=
HOTPATH_LOG_LEVEL=INFO

# ── Runtime ───────────────────────────────────────────────────────────────────
HOTPATH_API_PORT=8000
# Activa el endpoint síncrono /v1/classify para pruebas locales sin Event Hubs
HOTPATH_ENABLE_SYNC_API=true
# Activa el modo dead-letter (en vez de fail-loud) para mensajes problemáticos
HOTPATH_DEAD_LETTER_MODE=false
